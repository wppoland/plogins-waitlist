#. Found in description list item.
msgid "Optional heading and intro text shown above the form"
msgstr "Optionale Überschrift und Einleitungstext über dem Formular"

#. Found in description list item.
msgid ""
"Automatic plain-text email notification on restock, sent via "
"<code>wp_mail</code>"
msgstr ""
"Automatische Nur-Text-E-Mail-Benachrichtigung beim Wiederauffüllen, gesendet"
